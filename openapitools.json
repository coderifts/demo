{
  "$schema": "node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.0.0",
    "generators": {
      "typescript-client": {
        "generatorName": "typescript-axios",
        "output": "clients/typescript"
      },
      "java-client": {
        "generatorName": "java",
        "output": "clients/java"
      }
    }
  }
}
